{
  "compilerOptions": {
    "target": "es2022",
    "module": "Node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "moduleResolution": "node16",
    "strictBindCallApply": true,
    //    "declaration": true,
    "paths": {
      "logic": [
        "./logic/src/index.ts"
      ]
    }
  },
  "include": [
    "client/src",
    "server/src",
    "logic/src"
  ],
  "exclude": [
    "node_modules"
  ]
}